<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="WpfPlayground.MainWindow"
        Title="Camera Settings"
        Width="600"
        Height="400">

    <StackPanel Margin="20">
        <GroupBox Header="Image">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="6*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions >
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <Label Content="Brightness" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Slider Name="BrightnessSlider" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="10" Value="0" Minimum="-10" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="BrightnessSlider_ValueChanged"/>
                <TextBlock Text="0" Name="BrightnessValue" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"/>

                <Label Content="Contrast" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Slider Name="ContrastSlider" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="10" Value="0" Minimum="-10" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="ContrastSlider_ValueChanged"/>
                <TextBlock Text="0" Name="ContrastValue" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"/>

                <Label Content="Saturation" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Slider Name="SaturationSlider" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="10" Value="0" Minimum="-10" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SaturationSlider_ValueChanged"/>
                <TextBlock Text="0" Name="SaturationValue" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"/>

                <CheckBox Content="HDR" Grid.Row="3" VerticalAlignment="Center" Margin="10,0,0,0" IsChecked="True"/>
                <CheckBox Content="Mirror" Grid.Row="4" VerticalAlignment="Center" Margin="10,0,0,0" IsChecked="True"/>

            </Grid>
        </GroupBox>

        <GroupBox Header="Output">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="10*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions >
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <Label Content="Resolution" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox Grid.Row="0" Grid.Column="1"  HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" SelectedIndex="0">
                    <ComboBoxItem Content="1920 x 1080"/>
                    <ComboBoxItem Content="1760 x 990"/>
                    <ComboBoxItem Content="1680 x 1050"/>
                </ComboBox>

                <Label Content="FPS" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1"  HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" SelectedIndex="0">
                    <ComboBoxItem Content="60"/>
                    <ComboBoxItem Content="50"/>
                    <ComboBoxItem Content="40"/>
                    <ComboBoxItem Content="30"/>
                    <ComboBoxItem Content="20"/>
                </ComboBox>
            </Grid>
        </GroupBox>
    </StackPanel>
</Window>